PORT=3001
JWT_SECRET=troque_por_um_segredo_forte
FRONTEND_URL=http://localhost:5173

# String de conexão do PostgreSQL. Localmente, use um Postgres próprio (Docker, instalação
# local, ou uma instância gratuita na nuvem, ex: Neon/Supabase). Em produção, use a connection
# string fornecida pelo Neon (ou o provedor de banco escolhido).
DATABASE_URL=postgresql://usuario:senha@localhost:5432/moneytrack?schema=public

# SMTP — usado para enviar o e-mail de redefinição de senha.
# Exemplo com Gmail: crie uma "App Password" em https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@gmail.com
SMTP_PASS=sua_app_password
EMAIL_FROM=MoneyTrack <seu@gmail.com>
